<%- include('../partials/header', { title: "Sales Report" }) %>
<%- include('../partials/sidebar') %>

<div class="main">
  <%- include('../partials/navbar', { pageTitle }) %>
  <h2>Sales Report</h2>

  <table>
    <thead>
      <tr>
        <th>Receipt</th>
        <th>Date</th>
        <th>Items</th>
        <th>Payment</th>
        <th>Total</th>
        <th>Profit</th>
      </tr>
    </thead>
    <tbody>
      <% if (sales.length === 0) { %>
        <tr>
          <td colspan="6">No sales have been recorded yet.</td>
        </tr>
      <% } %>

      <% sales.forEach((sale) => { %>
        <tr>
          <td><a href="/receipts/<%= sale.id %>"><%= sale.receiptNumber %></a></td>
          <td><%= new Date(sale.createdAt).toLocaleString() %></td>
          <td><%= sale.items.reduce((sum, item) => sum + item.quantity, 0) %></td>
          <td><%= sale.payment.method.toUpperCase() %></td>
          <td>GHS <%= Number(sale.subtotal).toFixed(2) %></td>
          <td>GHS <%= Number(sale.profit).toFixed(2) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
